<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.control.DialogPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>

<DialogPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ua.praktik.controller.AddBookDialogController">
  <content>
    <GridPane hgap="10.0" vgap="10.0">
      <columnConstraints>
        <ColumnConstraints hgrow="SOMETIMES" maxWidth="150.0" minWidth="100.0"/>
        <ColumnConstraints hgrow="SOMETIMES" maxWidth="300.0" minWidth="200.0"/>
      </columnConstraints>
      <rowConstraints>
        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
      </rowConstraints>
      <children>
        <Label text="Назва:"/>
        <Label text="Автор:" GridPane.rowIndex="1"/>
        <Label text="ISBN:" GridPane.rowIndex="2"/>
        <Label text="Рік видання:" GridPane.rowIndex="3"/>
        <Label text="Видавництво:" GridPane.rowIndex="4"/>
        <Label text="Ціна:" GridPane.rowIndex="5"/>
        <Label text="Кількість сторінок:" GridPane.rowIndex="6"/>
        <Label text="Шлях до зображення:" GridPane.rowIndex="7"/>
        <TextField fx:id="titleField" promptText="Назва" GridPane.columnIndex="1"/>
        <TextField fx:id="authorField" promptText="Автор" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        <TextField fx:id="isbnField" promptText="ISBN" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
        <TextField fx:id="yearField" promptText="Рік видання" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
        <TextField fx:id="publisherField" promptText="Видавництво" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
        <TextField fx:id="priceField" promptText="Ціна" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
        <TextField fx:id="pageCountField" promptText="Кількість сторінок" GridPane.columnIndex="1" GridPane.rowIndex="6"/>
        <TextField fx:id="imagePathField" promptText="Шлях до зображення" GridPane.columnIndex="1" GridPane.rowIndex="7"/>
      </children>
    </GridPane>
  </content>
</DialogPane>
