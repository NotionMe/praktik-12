<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ua.praktik.controller.MainController">
  <top>
    <ImageView fx:id="largeImageView" fitHeight="200" fitWidth="300" pickOnBounds="true" preserveRatio="true" BorderPane.alignment="CENTER" />
  </top>
  <center>
    <HBox prefHeight="580.0" prefWidth="980.0" BorderPane.alignment="CENTER">
      <children>
        <VBox>
          <children>
            <ProgressBar fx:id="progressBar" prefWidth="317.0" visible="false" />
            <TableView fx:id="userTable" prefHeight="550.0" prefWidth="800.0">
            </TableView>
          </children>
        </VBox>
        <VBox spacing="5">
          <children>
            <HBox spacing="5">
              <children>
                <ComboBox fx:id="choiceMouse" prefWidth="150.0" />
                <TextField fx:id="inputText" prefHeight="26.0" prefWidth="90.0" promptText="Search..." />
              </children>
            </HBox>
            <HBox spacing="5">
              <children>
                <Button fx:id="findBtn" mnemonicParsing="false" onAction="#onFind" text="Find" />
                <Button fx:id="getBtn" mnemonicParsing="false" onAction="#onGet" text="Get All" />
                <Button fx:id="addBtn" mnemonicParsing="false" onAction="#onAdd" text="Add" />
              </children>
            </HBox>
          </children>
        </VBox>
      </children>
    </HBox>
  </center>
</BorderPane>
